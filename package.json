{
  "name": "amazon-automation-framework",
  "version": "1.0.0",
  "description": "Playwright + Cucumber + TypeScript automation framework for Amazon with Page Object Model",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js",
    "test:headed": "HEADED=true cucumber-js",
    "test:debug": "cucumber-js --dry-run",
    "test:report": "open test-results/cucumber-report.html",
    "build": "tsc --noEmit",
    "prebuild": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "cucumber",
    "typescript",
    "pom",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@cucumber/pretty-formatter": "^1.0.0",
    "@playwright/test": "^1.59.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
